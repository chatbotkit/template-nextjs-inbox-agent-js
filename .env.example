# The ChatBotKit Secret Token
# obtain a new token from https://chatbotkit.com/tokens
CHATBOTKIT_API_SECRET=

# The ChatBotKit Bot ID for processing emails
# create a bot at https://chatbotkit.com/bots with Gmail abilities
CHATBOTKIT_BOT_ID=

# NextAuth configuration
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (for user sign-in only)
# create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
